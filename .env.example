# Supported OCR engines: paddle or gemini
LOTTE_OCR_ENGINE=paddle

# Only required for Gemini Vision OCR
GOOGLE_API_KEY=your_google_api_key_here

# Limit number of images processed during development
LOTTE_MAX_IMAGES=3

# Use local HTML test mode for debugging
LOTTE_TEST_MODE=false

# Qwen2.5VL model for OCR: 3b (default, fits 8GB VRAM) or 7b (better accuracy, needs ~5GB)
QWN_MODEL=3b
